# ---- CollegeGene AI server environment ----
# Copy this file to .env and fill in your keys. NEVER commit .env.

# College Scorecard (U.S. Dept. of Education). Get a free key in ~1 min at:
#   https://api.data.gov/signup/
# If omitted, the app uses the public DEMO_KEY (1,000 req/hr, 10,000/day) so you
# can try it immediately — but register your own key for real use.
COLLEGE_SCORECARD_API_KEY=

# Bureau of Labor Statistics (optional). Registration raises API limits:
#   https://data.bls.gov/registrationEngine/
# If omitted, career pages use the bundled, dated BLS OOH snapshot.
BLS_API_KEY=

# Server port (default 4000)
PORT=4000

# Cache time-to-live for live API responses, ms (default 24h)
CACHE_TTL_MS=86400000

# Flag cached rows older than this as "stale", ms (default 7 days)
STALE_AFTER_MS=604800000

# SQLite database file path
DB_PATH=./collegegene.db

# Optional Google Gemini key — enables AI auto-fill of profile from uploaded
# transcripts/resumes. Get a FREE key at https://aistudio.google.com/apikey
# Without it, uploads still work; you just confirm fields manually.
# NOTE: on Google's free tier, inputs may be used to improve their models.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Where uploaded documents are stored (local disk)
UPLOAD_DIR=./uploads

# ---- Firebase Admin (identity verification only; SERVER-ONLY secrets) ----
# Preferred (easiest on Railway): the entire service account JSON as ONE line.
# Firebase Console -> Project settings -> Service accounts -> Generate new private
# key, then paste the file's contents here as a single-line string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternative to the JSON blob: the three discrete fields. If you use these,
# keep the private key's \n escapes intact (the server restores real newlines).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- Local development only ----
# Bypasses auth so you can run without Firebase configured. NEVER takes effect
# when NODE_ENV=production. Leave unset unless you need it locally.
# AUTH_DEV_BYPASS=true
# NODE_ENV=development
