# CollegeGene AI — client (Vite) environment variables.
# These Firebase WEB config values are public by design (safe to ship in the
# browser bundle). The private service account lives only on the server.
# Copy this file to `.env` (or `.env.local`) and fill in your Firebase web app values,
# found in Firebase Console → Project settings → Your apps → SDK setup and configuration.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
