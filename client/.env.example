# CollegeGene AI — client (Vite) environment variables.
#
# These Firebase WEB config values are PUBLIC by design (they ship in the browser
# bundle; Firebase intends this). The private service account lives ONLY on the
# server — never put it here.
#
# Copy this file to `.env` in the `client/` folder and fill in your values from
# Firebase Console -> Project settings -> Your apps -> SDK setup and configuration.
# Vite only reads these at STARTUP/BUILD, so restart `npm run dev` after editing.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# NOTE: There is intentionally no VITE_API_BASE_URL.
# This app is same-origin by design: the client calls relative "/api/..." paths.
#  - In dev, vite.config.js proxies /api -> http://localhost:4000
#  - In production, the Express server serves the built client from the same origin
# Adding an API base URL would introduce unnecessary cross-origin/CORS complexity.
